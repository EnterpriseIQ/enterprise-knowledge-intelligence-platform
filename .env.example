# Example environment configuration for the Secure Enterprise RAG Platform.
# Copy to `.env` and adjust. All variables are optional — sane defaults live in
# src/config.py. Values here are read automatically on startup (via python-dotenv)
# and can also be supplied as real environment variables (e.g. in Docker/CI).

# --- Paths ---------------------------------------------------------------------
# ERAG_DATA_DIR=./data
# ERAG_VECTORSTORE_DIR=./data/vectorstore
# ERAG_COLLECTION=enterprise_corpus

# --- Chunking ------------------------------------------------------------------
ERAG_CHUNK_SIZE=900
ERAG_CHUNK_OVERLAP=150

# --- Embeddings ----------------------------------------------------------------
# SentenceTransformers model; falls back to a deterministic hashing embedder if
# the weights cannot be loaded (e.g. offline). The platform runs either way.
ERAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
ERAG_EMBEDDING_DIM=384

# --- Retrieval -----------------------------------------------------------------
ERAG_TOP_K=5
ERAG_CANDIDATE_K=20
# Weight of dense (semantic) vs sparse (BM25) in fusion. 1.0 = dense only.
ERAG_HYBRID_ALPHA=0.6

# --- Confidence thresholds -----------------------------------------------------
ERAG_CONF_HIGH=0.55
ERAG_CONF_LOW=0.30

# --- Optional, provider-agnostic LLM generation backend -----------------------
# Set to 1 to enable the optional LLM generator (context-only, cite-or-refuse).
# Default (unset) uses the safe extractive generator — zero hallucination, no keys.
# ERAG_LLM=1
# Model id for the implemented provider (Anthropic):
# ERAG_LLM_MODEL=claude-opus-4-8
# Provide the key for the active provider (Anthropic is currently implemented;
# OpenAI / Gemini / Ollama / OpenRouter / self-hosted plug into the same seam):
# ANTHROPIC_API_KEY=

# --- Offline / Hugging Face hints (used in Docker) -----------------------------
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
